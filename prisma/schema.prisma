generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  balance       Decimal   @default(0) @db.Decimal(12, 2)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  propAccounts PropAccount[]
  transactions Transaction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PropAccount {
  id             String        @id @default(cuid())
  userId         String
  accountSize    AccountSize
  challengeType  ChallengeType
  status         AccountStatus @default(PENDING)
  profitTarget   Decimal?      @db.Decimal(12, 2)
  currentBalance Decimal       @default(0) @db.Decimal(12, 2)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  propAccountId   String?
  amount          Decimal           @db.Decimal(12, 2)
  currency        String            @default("UZS")
  status          TransactionStatus @default(PENDING)
  paymentMethod   PaymentMethod
  clickTransId    String?           @unique
  paymeTransId    String?           @unique
  merchantTransId String            @unique @default(cuid())
  description     String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  propAccount PropAccount? @relation(fields: [propAccountId], references: [id])

  @@index([userId])
  @@index([clickTransId])
  @@index([paymeTransId])
}

enum Role {
  USER
  ADMIN
}

enum AccountSize {
  SIZE_5K
  SIZE_10K
  SIZE_25K
  SIZE_50K
  SIZE_100K
}

enum ChallengeType {
  STRIKE_1
  INSTANT
  ONE_STEP
  TWO_STEP
}

enum AccountStatus {
  PENDING
  ACTIVE
  PASSED
  FAILED
  FUNDED
}

enum TransactionStatus {
  PENDING
  PREPARING
  COMPLETED
  CANCELLED
  FAILED
}

enum PaymentMethod {
  CLICK
  PAYME
}