# ─── .env.local ──────────────────────────────────────────────────────────────
# Bu faylni .gitignore ga qo'shing! Hech qachon git'ga push qilmang!

# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/propfirm_db"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# openssl rand -base64 32  →  bu buyruq bilan tasodifiy secret yarating
NEXTAUTH_SECRET="your-super-secret-key-minimum-32-chars"
NEXTAUTH_URL="http://localhost:3000"  # Production'da: https://yourdomain.com

# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Click.uz ────────────────────────────────────────────────────────────────
# Click merchant panel → Settings → API
CLICK_SERVICE_ID="12345"
CLICK_MERCHANT_ID="67890"
CLICK_SECRET_KEY="your-click-secret-key"
CLICK_MERCHANT_USER_ID="your-merchant-user-id"

# ─── Payme (future) ──────────────────────────────────────────────────────────
PAYME_MERCHANT_ID="your-payme-merchant-id"
PAYME_SECRET_KEY="your-payme-secret-key"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
